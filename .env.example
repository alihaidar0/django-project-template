# ============================================================
#  .env.example
#  Copy to .env for local development.
#  Production secrets go in GCP Secret Manager — NOT here.
#  NEVER commit .env
# ============================================================


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  DJANGO CORE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SECRET_KEY=dev-secret-key-replace-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_LOG_LEVEL=INFO
API_TITLE=My Django API
API_DESCRIPTION=REST API


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  DATABASE
#  Dev:  local PostgreSQL via docker-compose
#  Prod: Neon (serverless PostgreSQL)
#
#  Neon setup:
#    1. neon.tech → Create project → Create database
#    2. Connection Details → select "psycopg2" format
#    3. Copy the connection string into GCP Secret Manager
#       as "database-url"
#
#  Neon connection string format:
#  postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
#
#  Tips:
#    - Always use sslmode=require (Neon enforces TLS)
#    - Use "pooled" connection string for better performance
#    - Create separate Neon branches for staging and production
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_DB=django_dev
POSTGRES_USER=django
POSTGRES_PASSWORD=django_pass
DATABASE_URL=postgres://django:django_pass@db:5432/django_dev


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  REDIS
#  Dev:  local Redis via docker-compose
#  Prod: Upstash Redis (recommended — serverless, no infra)
#
#  Upstash setup:
#    1. upstash.com → Create database → select region
#    2. Copy "Redis URL" (starts with rediss://) into
#       GCP Secret Manager as "redis-url"
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  CLOUDFLARE R2 — Static + Media Files
#
#  Setup steps:
#    1. Cloudflare Dashboard → R2 → Create bucket
#    2. R2 → Manage R2 API Tokens → Create Token
#         Permissions: Object Read & Write
#    3. Get Account ID from R2 overview page (top right)
#    4. Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#    5. Optional: Add custom domain (recommended)
#         R2 → your bucket → Settings → Custom Domains
#         Point your CDN subdomain here: cdn.yourdomain.com
#
#  In production — add all R2 values to GCP Secret Manager:
#    r2-access-key, r2-secret-key, r2-bucket-name,
#    r2-endpoint-url, r2-custom-domain
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
USE_S3=False
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=your-bucket-name
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_CUSTOM_DOMAIN=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  GCP CLOUD RUN
#
#  Setup steps:
#    1. console.cloud.google.com → Create project
#    2. Enable APIs:
#         Cloud Run API
#         Secret Manager API
#         Cloud Build API
#    3. IAM → Service Accounts → Create account
#         Grant roles:
#           roles/run.admin
#           roles/secretmanager.secretAccessor
#           roles/iam.serviceAccountUser
#    4. Create JSON key → paste into GitHub Secret: GCP_SA_KEY
#    5. Create Cloud Run services (staging + prod)
#    6. Add all secrets to GCP Secret Manager
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
CLOUD_RUN_SERVICE_STAGING=django-api-staging
CLOUD_RUN_SERVICE_PROD=django-api


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  DOCKER HUB
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DOCKERHUB_USERNAME=your-dockerhub-username


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  JWT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  EMAIL
#  Dev:  Mailpit (catches all locally at localhost:8025)
#  Prod: Resend / SendGrid / SES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  CORS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
