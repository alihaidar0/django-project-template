# ============================================================
#  .dockerignore
#  Controls what is EXCLUDED from the Docker build context.
#  Every line here = smaller image, faster build, no secrets.
#
#  Rule of thumb: whitelist what you need, blacklist everything else.
#  The prod image should contain ONLY: source code + configs.
# ============================================================

# ── Git ──────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github

# ── Docker (never nest Docker inside Docker context) ─────────
.dockerignore
docker-compose*.yml
docker/

# ── Dev Container ────────────────────────────────────────────
.devcontainer

# ── Python cache & build artifacts ──────────────────────────
__pycache__
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────
.venv
venv/
env/
ENV/
.uv/

# ── Test + coverage ──────────────────────────────────────────
.pytest_cache
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml

# ── Type checking ────────────────────────────────────────────
.mypy_cache
.dmypy.json
.pytype/
.ruff_cache/

# ── Secrets — CRITICAL: never bake secrets into images ───────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
service-account*.json
gcp-credentials*.json
secrets/

# ── Local data (must not go into prod image) ─────────────────
media/
staticfiles/
*.sqlite3
*.db

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# ── OS artifacts ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Documentation (not needed in runtime image) ──────────────
docs/
*.md
!README.md

# ── CI artifacts ─────────────────────────────────────────────
.github/
*.tar.gz
*.zip

# ── Husky / commitlint (dev tooling) ─────────────────────────
.husky/
commitlint.config.cjs
package.json
package-lock.json